<interface>
  <!-- interface-license-type gplv3 -->
  <!-- interface-name GNOME Podcasts -->
  <!-- interface-description A podcast client for the GNOME Desktop -->
  <!-- interface-copyright 2017 - 2026 -->
  <!-- interface-authors Jordan Petridis\nTobias Bernard -->
  <template class="PdHomeView" parent="AdwBin">
    <child>
      <object class="AdwToolbarView" id="search_bar_parent">
        <child type="top">
          <object class="GtkSearchBar" id="search_bar">
            <property name="child">
              <object class="GtkSearchEntry" id="search_entry">
                <property name="width-request">300</property>
                <property name="search-delay">500</property>
              </object>
            </property>
          </object>
        </child>
        <property name="content">
          <object class="PdBaseView" id="view">
            <property name="vexpand">True</property>
            <property name="child">
              <object class="AdwClamp">
                <property name="maximum-size">700</property>
                <child>
                  <object class="AdwBin" id="episode_list_container">
                    </object>
                </child>
              </object>
            </property>
          </object>
        </property>
      </object>
    </child>
  </template>
</interface>
